generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------
// User & Auth Configuration
// -----------------------------------------
// This maps to Supabase Auth user IDs.
model User {
  id         String      @id @db.Uuid // Supabase Auth User ID
  email      String      @unique
  full_name  String?
  avatar_url String?
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  
  workspaces Workspace[]
  notes      Note[]
  tags       Tag[]

  @@map("users")
}

// -----------------------------------------
// Workspaces / Projects (Top Level)
// -----------------------------------------
model Workspace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  color       String?  // For UI styling
  icon        String?  // emoji or lucide icon name
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  
  user_id     String   @db.Uuid
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  folders     Folder[]
  notes       Note[]
  tags        Tag[]

  @@index([user_id])
  @@map("workspaces")
}

// -----------------------------------------
// Folders (Nested Hierarchy)
// -----------------------------------------
model Folder {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  
  workspace_id String  @db.Uuid
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  
  // Self-relation for nested folders
  parent_id   String?  @db.Uuid
  parent      Folder?  @relation("FolderToFolder", fields: [parent_id], references: [id])
  children    Folder[] @relation("FolderToFolder")
  
  notes       Note[]

  @@index([workspace_id])
  @@map("folders")
}

// -----------------------------------------
// Note / Task Card (Kanban Support)
// -----------------------------------------
model Note {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  content     String?  // Markdown/JSON content from Rich Editor
  
  // Kanban Status
  status      String   @default("Ice Box") // "Ice Box", "In Progress", "Discussion", "Completed"
  priority    String?  // "Low", "Medium", "High"
  due_date    DateTime? @db.Timestamptz(6)
  
  file_url    String?
  
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  
  // Relations
  user_id     String   @db.Uuid
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  workspace_id String? @db.Uuid
  workspace    Workspace? @relation(fields: [workspace_id], references: [id])
  
  folder_id   String?  @db.Uuid
  folder      Folder?  @relation(fields: [folder_id], references: [id])
  
  tags        NoteTag[]

  @@index([user_id])
  @@index([workspace_id])
  @@index([folder_id])
  @@map("notes")
}

// -----------------------------------------
// Tags & Internal Linking
// -----------------------------------------
model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  color       String?  // Hex code for UI
  
  user_id     String   @db.Uuid
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  workspace_id String? @db.Uuid
  workspace    Workspace? @relation(fields: [workspace_id], references: [id])
  
  notes       NoteTag[]

  @@unique([name, user_id]) // Unique tag name per user
  @@map("tags")
}

// Join table for many-to-many Note <-> Tag
model NoteTag {
  note_id String @db.Uuid
  tag_id  String @db.Uuid
  
  note    Note   @relation(fields: [note_id], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([note_id, tag_id])
  @@map("note_tags")
}
